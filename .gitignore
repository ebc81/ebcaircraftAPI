tmp/
temp/
pids/
*.pid
*.seed
*.pid.lock

# ── Build output ──────────────────────────────────────────────────────────────
dist/
build/
.cache/

# ── Coverage & testing ────────────────────────────────────────────────────────
coverage/
.nyc_output/

